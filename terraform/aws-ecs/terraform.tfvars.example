# Terraform Variables Example Template
#
# This is an EXAMPLE file showing all configurable variables.
#
# TO USE:
# 1. Copy this file: cp terraform.tfvars.example terraform.tfvars
# 2. Edit terraform.tfvars with YOUR values
# 3. Run: terraform apply
#
# NOTE: terraform.tfvars is in .gitignore and will NOT be committed to git

# ============================================================================
# NETWORK CONFIGURATION - IP ADDRESSES
# ============================================================================

# Main ALB (Registry, Auth Server, Gradio) - Allowed IP addresses
# These IPs can access:
#   - http://mcp-gateway-alb-*.us-east-1.elb.amazonaws.com (ports 80, 443)
#   - http://mcp-gateway-alb-*.us-east-1.elb.amazonaws.com:7860 (Registry)
#   - http://mcp-gateway-alb-*.us-east-1.elb.amazonaws.com:8888 (Auth Server)
ingress_cidr_blocks = [
  "71.114.44.148/32",      # Example: Your laptop IP
  "44.192.72.20/32"        # Example: Your EC2 instance IP
]

# Keycloak ALB - Primary IP (usually your laptop/dev machine)
# This IP can access: http://mcp-gateway-kc-alb-*.us-east-1.elb.amazonaws.com:8080
keycloak_ingress_cidr = "71.114.44.148/32"

# Keycloak ALB - Secondary IP (usually your EC2 instance)
# This IP can also access: http://mcp-gateway-kc-alb-*.us-east-1.elb.amazonaws.com:8080
keycloak_ingress_cidr_ec2 = "44.192.72.20/32"

# ============================================================================
# KEYCLOAK ALB CONFIGURATION
# ============================================================================

# Make Keycloak ALB internet-facing (public) or internal (private only)
# Options: "internet-facing" or "internal"
keycloak_alb_scheme = "internet-facing"

# ============================================================================
# KEYCLOAK OAUTH2 CONFIGURATION
# ============================================================================

# Keycloak Web Client Secret
# Get this from: Keycloak Admin Console > Clients > mcp-gateway-web > Credentials > Secret
# Default: "change-me-to-keycloak-web-client-secret"
keycloak_client_secret = "change-me-to-keycloak-web-client-secret"

# Keycloak M2M (Machine-to-Machine) Client Secret
# Get this from: Keycloak Admin Console > Clients > mcp-gateway-m2m > Credentials > Secret
# Default: "change-me-to-keycloak-m2m-client-secret"
keycloak_m2m_client_secret = "change-me-to-keycloak-m2m-client-secret"

# ============================================================================
# OPTIONAL: ADDITIONAL CONFIGURATION
# ============================================================================

# AWS Region
# Default: "us-east-1"
# aws_region = "us-east-1"

# Deployment name prefix
# Default: "mcp-gateway"
# name = "mcp-gateway"

# VPC CIDR block
# Default: "10.0.0.0/16"
# vpc_cidr = "10.0.0.0/16"

# SSL Certificate ARN (optional)
# Leave empty for HTTP-only, provide ACM certificate ARN for HTTPS
# certificate_arn = ""

# Enable CloudWatch monitoring
# Default: true
# enable_monitoring = true

# Email for alarm notifications (optional)
# alarm_email = ""
